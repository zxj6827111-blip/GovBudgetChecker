# ========================================
# GovBudgetChecker Environment Configuration
# ========================================
# Copy this file to .env and update values as needed
# cp .env.example .env

# ----------------------------------------
# PostgreSQL Database Configuration
# ----------------------------------------
# 本地原生安装的 PostgreSQL 连接 URL
# 格式: postgres://用户名:密码@主机:端口/数据库名
# 示例（根据你的实际配置修改）:
DATABASE_URL=postgres://postgres:your_password@localhost:5432/fiscal_db

# PostgreSQL schema (default: public)
# Future: Can use different schemas for multi-tenant or co-located databases
# Example: PG_SCHEMA=fiscal for dedicated schema
PG_SCHEMA=public

# ----------------------------------------
# AI Provider Configuration
# ----------------------------------------
# Recommended: use stable logical slots so future provider/model changes only
# need .env updates. Supported slot names are:
# - main: primary full-report audit
# - backup: fallback if main fails
# - locator: page/location enhancement
#
# Common provider types:
# - openai_compat: Gemini gateway / Codex gateway / Kimi / most OpenAI-compatible APIs
# - zhipu: Zhipu native provider
# - doubao: Ark / Doubao native provider

AI_MAIN_PROVIDER=main
AI_MAIN_MODEL=gpt-5.4
AI_MAIN_PROVIDER_TYPE=openai_compat
AI_MAIN_BASE_URL=https://your-openai-compatible-main-endpoint/v1
AI_MAIN_API_KEY=your_main_api_key

# Optional override. If left empty, audit inherits AI_MAIN_PROVIDER + AI_MAIN_MODEL.
AI_AUDIT_PROVIDER=
AI_AUDIT_MODEL=

AI_BACKUP_PROVIDER_TYPE=openai_compat
AI_BACKUP_BASE_URL=https://your-openai-compatible-backup-endpoint/v1
AI_BACKUP_API_KEY=your_backup_api_key
AI_BACKUP_MODEL=gemini-2.5-pro

AI_LOCATOR_PROVIDER=locator
AI_LOCATOR_MODEL=gemini-2.5-flash
AI_LOCATOR_PROVIDER_TYPE=openai_compat
AI_LOCATOR_BASE_URL=https://your-openai-compatible-locator-endpoint/v1
AI_LOCATOR_API_KEY=your_locator_api_key

AI_FALLBACK_CHAIN=main,backup,locator

# Legacy named-provider variables (optional compatibility).
# Keep these only if you still want to use gemini_main / codex_backup style names.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://your-openai-compatible-gemini-endpoint/v1
GEMINI_MAIN_MODEL=gemini-2.5-pro
GEMINI_LOCATOR_MODEL=gemini-2.5-flash

CODEX_API_KEY=
CODEX_BASE_URL=https://your-openai-compatible-codex-endpoint/v1
CODEX_MODEL=gpt-5.4

# ----------------------------------------
# System Configuration
# ----------------------------------------
AI_ASSIST_ENABLED=true
AI_EXTRACTOR_URL=http://127.0.0.1:9009/ai/extract/v1
AI_EXTRACTOR_DIRECT_FALLBACK=true

# Runtime storage.
# Recommended: keep these outside the git repository to avoid data being
# overwritten by git pull / branch switch and to keep local/cloud layouts aligned.
#
# Linux server example:
# HOST_DATA_DIR=/opt/GovBudgetChecker-data/data
# HOST_LOGS_DIR=/opt/GovBudgetChecker-data/logs
# HOST_SAMPLES_DIR=/opt/GovBudgetChecker-data/samples
# HOST_UPLOADS_DIR=/opt/GovBudgetChecker-data/uploads
#
# Windows local example (use forward slashes):
# HOST_DATA_DIR=D:/GovBudgetChecker-data/data
# HOST_LOGS_DIR=D:/GovBudgetChecker-data/logs
# HOST_SAMPLES_DIR=D:/GovBudgetChecker-data/samples
# HOST_UPLOADS_DIR=D:/GovBudgetChecker-data/uploads
HOST_DATA_DIR=/opt/GovBudgetChecker-data/data
HOST_LOGS_DIR=/opt/GovBudgetChecker-data/logs
HOST_SAMPLES_DIR=/opt/GovBudgetChecker-data/samples
HOST_UPLOADS_DIR=/opt/GovBudgetChecker-data/uploads

# ----------------------------------------
# API Security (Required in production)
# ----------------------------------------
GOVBUDGET_AUTH_ENABLED=true
GOVBUDGET_API_KEY=change_me_to_a_strong_secret
GOVBUDGET_RATE_LIMIT=100
USER_SESSION_SECRET=change_me_to_a_different_strong_secret
AUDIT_LOG_PATH=/opt/GovBudgetChecker-data/logs/admin-actions.jsonl

# Upload hard limits
MAX_UPLOAD_MB=30
MAX_UPLOAD_PAGES=800

# ----------------------------------------
# Queue / Batch flow
# ----------------------------------------
# AI串行（推荐开启）：AI逐个审查，避免并发限流
AI_SEQUENTIAL_MODE=true
# 本地任务并发数；未设置时在AI串行模式下会自动取>=10
# JOB_QUEUE_WORKERS=12

# Queue role:
# - all: API process also runs local queue workers (default)
# - api: API only enqueues jobs, no local execution (recommended for split deployment)
# - worker: dedicated worker process consumes queue jobs
JOB_QUEUE_ROLE=all

# Whether API process can fallback to in-process execution when local queue is absent.
# For split deployment, set false in API process and run dedicated worker process.
JOB_QUEUE_INLINE_FALLBACK=true
